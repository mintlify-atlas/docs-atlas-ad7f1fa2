  "keyFeatures": [
    "Offline-first with local database and automatic sync across devices",
    "Rich text editor with bold, italic, headings, lists, and checkboxes",
    "Note sharing with viewer or editor permissions",
    "Tags system with custom colors for note organization",
    "Note backgrounds with solid colors and patterns",
    "Pin and archive notes for quick access and organization",
    "Full-text search by title or content",
    "Soft delete with trash and recovery",
    "Admin panel for user management and system settings",
    "OIDC authentication support (Pocket ID, Authelia, Keycloak, etc.)",
    "Self-hostable with Docker, supports embedded or external PostgreSQL",
    "Flutter mobile app with Android APK distribution"
  ],
